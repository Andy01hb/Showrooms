# Supabase — valores de ejemplo. Copiá este archivo a `.env.local` y completá con
# los valores reales de `supabase status` (local) o del dashboard (staging/prod).
# `.env.local` está gitignored: NUNCA commitees claves reales.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Clave pública (antes "anon"). En Supabase moderno tiene formato sb_publishable_...
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me

# Solo server. NUNCA con prefijo NEXT_PUBLIC_. Nunca commitear el valor real.
# Clave secreta (antes "service_role"). Formato sb_secret_...
SUPABASE_SERVICE_ROLE_KEY=replace-me
